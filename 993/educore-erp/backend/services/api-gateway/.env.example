# EduCore API Gateway — Environment Variables
# Copy this to .env.local and fill in values. NEVER commit .env.local

# ─── JWT ────────────────────────────────────────────────────────────────────
# DEV ONLY: Change this to a 256-bit random secret in staging/prod
# Prod: loaded from HashiCorp Vault at startup
JWT_SECRET=educore-dev-secret-change-this-in-production-use-vault

# JWT expiry durations
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000
HOST=0.0.0.0
NODE_ENV=development

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ─── Database (not active in dev — uses in-memory mock) ─────────────────────
# DATABASE_URL=postgresql://user:pass@localhost:5432/educore_dev
# DATABASE_POOL_MIN=2
# DATABASE_POOL_MAX=10

# ─── Rate Limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=1 minute

# ─── Feature Flags ───────────────────────────────────────────────────────────
ENABLE_DEMO_ROUTES=true
ENABLE_AUDIT_LOG=true
